# Copy this file to .env and fill in your SAP system credentials.
# .env is gitignored — never commit real credentials.

# SAP system connection
VSP_HOST=https://your-sap-host:44300
VSP_USER=YOURUSER
VSP_PASSWORD=yourpassword
VSP_CLIENT=100

# Optional: override allowed packages (default: Z*,$TMP,$ZADT_VSP,$VSP_ADT)
# VSP_ALLOWED_PACKAGES=Z*,$TMP

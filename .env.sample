# Copy this file to .env and fill in your SAP system credentials.
# .env is gitignored — never commit real credentials.

# SAP system connection
SAP_URL=https://your-sap-host:44300
SAP_USER=YOURUSER
SAP_PASSWORD=yourpassword
SAP_CLIENT=100
SAP_LANGUAGE=EN

# SAP Mode: hyperfocused | focused | expert
SAP_MODE=hyperfocused

# Optional: override allowed packages (default: Z*,$TMP,$ZADT_VSP,$VSP_ADT)
# SAP_ALLOWED_PACKAGES=Z*,$TMP

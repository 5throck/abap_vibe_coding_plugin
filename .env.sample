# SAP System Connection
SAP_URL=http://<YOUR_SAP_HOST>:<PORT>
SAP_USER=<YOUR_USERNAME>
SAP_PASSWORD=<YOUR_PASSWORD>
SAP_CLIENT=<CLIENT_NUMBER>
SAP_LANGUAGE=EN

# SAP Mode: hyperfocused | focused | expert
# hyperfocused = 1 tool (sap_execute) — recommended for AI agents
SAP_MODE=hyperfocused

# Allowed packages (comma-separated, wildcards supported)
# Include $ZADT_VSP and $VSP_ADT to allow WebSocket debug infrastructure
SAP_ALLOWED_PACKAGES=Z*,$TMP,$ZADT_VSP,$VSP_ADT

# Feature flags
SAP_FEATURE_ABAPGIT=on

# ------------------------------------------------------------
# Example: SAP NetWeaver Trial (NPL)
# SAP_URL=http://vhcalnplci:50000
# SAP_USER=DEVELOPER
# SAP_PASSWORD=<YOUR_PASSWORD>
# SAP_CLIENT=001
#
# Example: Corporate system
# SAP_URL=https://your-sap-dev.company.com:44300
# SAP_USER=JSMITH
# SAP_PASSWORD=MySecurePass123
# SAP_CLIENT=100
# SAP_MODE=focused
# SAP_ALLOWED_PACKAGES=Z*,Y*,$TMP
# ------------------------------------------------------------
